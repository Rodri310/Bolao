"/* =====================================================\n   BOLÃO COPA DO MUNDO 2026 — Premium Dark Theme\n   Poppins via Google Fonts\n   ===================================================== */\n\n@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap');\n\n/* ---------- Design Tokens ---------- */\n:root {\n  --bg:          #060b14;\n  --bg-2:        #0d1421;\n  --bg-card:     rgba(255, 255, 255, 0.04);\n  --bg-card-hover: rgba(255, 255, 255, 0.07);\n  --border:      rgba(255, 255, 255, 0.08);\n  --border-gold: rgba(245, 166, 35, 0.35);\n\n  --gold:        #f5a623;\n  --gold-light:  #fbbf24;\n  --gold-dim:    rgba(245, 166, 35, 0.15);\n\n  --text:        #e2e8f0;\n  --text-2:      #94a3b8;\n  --text-3:      #475569;\n\n  --green:       #22c55e;\n  --green-bg:    rgba(34,  197, 94,  0.14);\n  --green-bd:    rgba(34,  197, 94,  0.35);\n\n  --amber:       #f59e0b;\n  --amber-bg:    rgba(245, 158, 11,  0.14);\n  --amber-bd:    rgba(245, 158, 11,  0.35);\n\n  --red:         #ef4444;\n  --red-bg:      rgba(239, 68,  68,  0.14);\n  --red-bd:      rgba(239, 68,  68,  0.35);\n\n  --gray:        #64748b;\n  --gray-bg:     rgba(100, 116, 139, 0.14);\n  --gray-bd:     rgba(100, 116, 139, 0.35);\n\n  --radius:      16px;\n  --radius-sm:   10px;\n  --radius-xs:   6px;\n  --shadow:      0 8px 32px rgba(0, 0, 0, 0.45);\n  --transition:  0.2s ease;\n}\n\n/* ---------- Reset ---------- */\n*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\nbody {\n  background-color: var(--bg);\n  background-image:\n    radial-gradient(ellipse 80% 40% at 20% 0%,   rgba(245,166,35,0.07) 0%, transparent 60%),\n    radial-gradient(ellipse 60% 40% at 80% 100%, rgba(34,197,94,0.04)  0%, transparent 60%);\n  background-attachment: fixed;\n  font-family: 'Poppins', system-ui, sans-serif;\n  color: var(--text);\n  min-height: 100vh;\n  font-size: 15px;\n}\n\n/* ---------- App Wrapper ---------- */\n.app-wrapper {\n  display: flex